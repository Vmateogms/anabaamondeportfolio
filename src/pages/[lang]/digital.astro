---
import PocketBase from 'pocketbase';
import Layout from '../../layouts/Layout.astro';

const { lang } = Astro.params;

if (lang !== 'es' && lang !== 'en') {
    return Astro.redirect('/es/');
}

const pb = new PocketBase(import.meta.env.PUBLIC_POCKETBASE_URL);
const registros = await pb.collection('digital').getFullList({ sort: '-created' });
const tituloVentana = lang === 'es' ? 'Digital' : 'Digital';

const currentPath = Astro.url.pathname;
const linkES = currentPath.replace(`/${lang}`, '/es');
const linkEN = currentPath.replace(`/${lang}`, '/en');
---

<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{tituloVentana} - Ana Baamonde</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap');

        :root {
            --color-fondo: #f4f4f4;
            --texto: #000;
        }

        body {
            margin: 0;
            background-color: var(--color-fondo);
            font-family: 'Inter', sans-serif;
            color: var(--texto);
        }

        .cabecera {
            position: fixed;
            top: 0; left: 0; width: 100%;
            padding: 40px;
            display: flex;
            justify-content: space-between;
            z-index: 100;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 14px;
            box-sizing: border-box;
            background: linear-gradient(to bottom, #f4f4f4 0%, #f4f4f4 80%, transparent 100%);
        }

        .idiomas a {
            text-decoration: none;
            color: #999;
            transition: color 0.3s;
            cursor: pointer;
        }
        .idiomas a:hover { color: #000; }

        .idiomas a.activo {
            color: #000;
            font-weight: bold;
            pointer-events: none;
        }

        .contenedor-principal {
            padding-top: 150px;
            padding-left: 40px;
            padding-right: 40px;
            padding-bottom: 80px;
            max-width: 1300px;
            margin: 0 auto;
        }

        .btn-volver {
            display: inline-block;
            text-decoration: none;
            color: #666;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 2px;
            margin-bottom: 60px;
            transition: color 0.3s;
            border-bottom: 1px solid transparent;
        }
        .btn-volver:hover {
            color: #000;
            border-bottom: 1px solid #000;
        }

        .galeria-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 100px;
            align-items: start;
        }

        .foto-item {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .foto-item h2 {
            font-size: 1.5rem;
            font-weight: 400;
            margin: 0;
            text-transform: uppercase;
            line-height: 1.2;
        }

        .foto-item .description {
            font-size: 0.95rem;
            line-height: 1.6;
            color: #444;
            font-weight: 300;
            margin: 0;
        }

        .foto-item .camara {
            font-size: 0.8rem;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .foto-item img {
            width: 100%;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            display: block;
            transition: transform 0.3s ease;
        }

        .foto-item img:hover {
            transform: scale(1.02);
        }

        @media (max-width: 1024px) {
            .galeria-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 40px;
            }
        }

        @media (max-width: 600px) {
            .galeria-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <div class="cabecera">
        <div><a href={`/${lang}/`} style="text-decoration:none; color:inherit;">@klluevabacardi</a></div>
        <div class="idiomas">
            <a href={linkES} class={lang === 'es' ? 'activo' : ''}>ES</a>
            <span> | </span>
            <a href={linkEN} class={lang === 'en' ? 'activo' : ''}>EN</a>
        </div>
    </div>

    <main class="contenedor-principal">

        <a href={`/${lang}/`} class="btn-volver">{lang === 'es' ? '← Volver' : '← Back'}</a>

        <div class="galeria-grid">
            {registros.map((registro) => {
                const url = pb.files.getURL(registro, registro.foto);
                const titulo = registro[`titulo_${lang}`];
                const descripcion = registro[`descripcion_${lang}`];
                const camara = registro.camara;

                return (
                    <article class="foto-item">
                        <div class="texto">
                            <h2>{titulo}</h2>
                            <div class="description" set:html={descripcion}></div>
                            <div class="camara" set:html={camara}></div>
                        </div>
                        <div class="imagen">
                            <img src={url} alt={titulo} />
                        </div>
                    </article>
                );
            })}
        </div>

    </main>

</body>
</html>