---
import PocketBase from 'pocketbase';
import Layout from '../../layouts/Layout.astro';

const { lang } = Astro.params;



const pb = new PocketBase(import.meta.env.PUBLIC_POCKETBASE_URL);
const info = await pb.collection('sobre_mi').getFirstListItem('id != ""');
const urlFoto = pb.files.getURL(info, info.foto);


const titulo = info[`titulo_${lang}`];
const bio = info[`bio_${lang}`];
const anchoFoto = info.ancho_foto || 100;

const currentPath = Astro.url.pathname;
const linkES = currentPath.replace(`/${lang}`, '/es');
const linkEN = currentPath.replace(`/${lang}`, '/en');
---

<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{titulo} - Ana Baamonde</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap');

        :root {
            --color-fondo: #f4f4f4;
            --texto: #000;
        }

        body {
            margin: 0;
            background-color: var(--color-fondo);
            font-family: 'Inter', sans-serif;
            color: var(--texto);
        }

        .cabecera {
            position: fixed;
            top: 0; left: 0; width: 100%;
            padding: 40px;
            display: flex;
            justify-content: space-between;
            z-index: 100;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 14px;
            box-sizing: border-box;
            background: linear-gradient(to bottom, #f4f4f4 0%, #f4f4f4 80%, transparent 100%);
        }

        .idiomas a {
            text-decoration: none;
            color: #999;
            transition: color 0.3s;
            cursor: pointer;
        }
        .idiomas a:hover { color: #000; }

        .idiomas a.activo {
            color: #000;
            font-weight: bold;
            pointer-events: none;
        }

        .contenedor-principal {
            padding-top: 150px;
            padding-left: 40px;
            padding-right: 40px;
            padding-bottom: 80px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .btn-volver {
            display: inline-block;
            text-decoration: none;
            color: #666;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 2px;
            margin-bottom: 60px;
            transition: color 0.3s;
            border-bottom: 1px solid transparent;
        }
        .btn-volver:hover {
            color: #000;
            border-bottom: 1px solid #000;
        }

        .grid-contenido {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: start;
        }

        h1 {
            font-size: 4rem;
            font-weight: 300;
            margin-top: 0;
            margin-bottom: 2rem;
            line-height: 1;
            text-transform: uppercase;
            letter-spacing: -1px;
        }

        .bio-texto {
            font-size: 1rem;
            line-height: 1.6;
            color: #333;
            font-weight: 300;
        }

        .bio-texto :global(p) {
            margin-bottom: 1.5rem;
        }

        .imagen-wrapper img {
            height: auto;
            display: block;
            margin-inline:auto;
        }

        @media (max-width: 768px) {
            .cabecera { padding: 20px; }
            .contenedor-principal { padding-top: 100px; padding-left: 20px; padding-right: 20px; }
            .grid-contenido {
                grid-template-columns: 1fr;
                gap: 40px;
            }
            .imagen-wrapper {
                order: -1;
            }
            h1 { font-size: 2.5rem; }
        }
    </style>
</head>
<body>

    <div class="cabecera">
        <div><a href={`/${lang}/`} style="text-decoration:none; color:inherit;">@klluevabacardi</a></div>
        <div class="idiomas">
            <a href={linkES} class={lang === 'es' ? 'activo' : ''}>ES</a>
            <span> | </span>
            <a href={linkEN} class={lang === 'en' ? 'activo' : ''}>EN</a>
        </div>
    </div>

    <main class="contenedor-principal">

        <a href={`/${lang}/`} class="btn-volver">
            {lang === 'es' ? '← Volver' : '← Back'}
        </a>

        <div class="grid-contenido">

            <div class="texto">
                <h1>{titulo}</h1>
                <div class="bio-texto" set:html={bio} />
            </div>

            <div class="imagen-wrapper">
                <img src={urlFoto} alt={titulo}  style={`width: ${anchoFoto}%`}/>
            </div>

        </div>

    </main>

</body>
</html>